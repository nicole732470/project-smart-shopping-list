<div class="pt-auth">
  <div class="pt-auth-grid">
    <aside class="pt-auth-side">
      <div class="pt-auth-mark">P/T</div>
      <div class="pt-auth-side-eyebrow">Welcome back</div>
      <h1 class="pt-auth-side-title">Sign in to keep watching prices.</h1>
      <p class="pt-auth-side-lede">
        We'll pick up where you left off, with every saved product and price
        observation right where it should be.
      </p>
      <div class="pt-auth-side-spec">
        <div class="pt-auth-side-row">
          <span class="pt-mono">01</span>
          <span>Paste a product link.</span>
        </div>
        <div class="pt-auth-side-row">
          <span class="pt-mono">02</span>
          <span>We grab the title, image, and current price.</span>
        </div>
        <div class="pt-auth-side-row">
          <span class="pt-mono">03</span>
          <span>Watch the chart for drops across stores.</span>
        </div>
      </div>
    </aside>

    <div class="pt-auth-form-wrap">
      <div class="pt-eyebrow">Sign in</div>
      <h2 class="pt-h1">Welcome back</h2>

      <% if params[:oauth_error] %>
        <div class="pt-flash" role="alert" style="margin-top: 16px; border-left: 3px solid var(--red);">
          <span class="pt-flash-icon" style="background: var(--red);">!</span>
          <div class="pt-flash-body">
            <div class="pt-flash-label">SIGN-IN FAILED</div>
            <div class="pt-flash-msg">We couldn't complete sign-in with that provider. Please try again.</div>
          </div>
        </div>
      <% end %>

      <%= button_to "/auth/google_oauth2",
            method: :post, data: { turbo: false },
            class: "pt-btn pt-btn-secondary pt-btn-lg pt-btn-block",
            form: { style: "margin-top: 24px;" } do %>
        <svg width="18" height="18" viewBox="0 0 24 24" aria-hidden="true" style="margin-right: 8px;">
          <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
          <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
          <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18A10.99 10.99 0 0 0 1 12c0 1.77.42 3.45 1.18 4.93l3.66-2.84z"/>
          <path fill="#EA4335" d="M12 5.38c1.62 0 3.07.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84C6.71 7.31 9.14 5.38 12 5.38z"/>
        </svg>
        Continue with Google
      <% end %>

      <div class="pt-auth-divider" style="display:flex;align-items:center;gap:12px;margin:16px 0;color:var(--muted);font-size:12px;">
        <span style="flex:1;height:1px;background:var(--line-2);"></span>
        <span>OR</span>
        <span style="flex:1;height:1px;background:var(--line-2);"></span>
      </div>

      <%= form_with url: session_path, local: true, class: "pt-auth-form" do |form| %>
        <div class="pt-form">
          <div class="pt-field">
            <label class="pt-field-label" for="email_address">Email address</label>
            <%= form.email_field :email_address,
                  required: true, autofocus: true, autocomplete: "username",
                  class: "pt-input", value: params[:email_address] %>
          </div>
          <div class="pt-field">
            <label class="pt-field-label" for="password">Password</label>
            <%= form.password_field :password,
                  required: true, autocomplete: "current-password", maxlength: 72,
                  class: "pt-input" %>
          </div>

          <%= form.submit "Sign in", class: "pt-btn pt-btn-primary pt-btn-lg pt-btn-block" %>
        </div>

        <div class="pt-auth-foot">
          New here? <%= link_to "Create an account", new_registration_path, class: "pt-link pt-link-strong" %>
        </div>
        <div class="pt-auth-links">
          <%= link_to "Forgot password?", new_password_path, class: "pt-link" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
