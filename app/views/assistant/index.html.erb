<main class="pt-page">
  <section class="pt-hero">
    <div class="container-xl">
      <div class="pt-eyebrow">AI Assistant</div>
      <h1 class="pt-h1">Ask anything about your watchlist</h1>
      <p class="pt-lede">
        Type a question in plain English. The assistant looks at the products you're tracking, their current and historical prices, and your target prices, then suggests up to <%= AiAssistant::MAX_PICKS %> picks with reasoning.
      </p>
    </div>
  </section>

  <section class="container-xl pt-content">
    <%= form_with url: assistant_path, method: :get, local: true, class: "pt-assistant-form" do |f| %>
      <div class="pt-field">
        <label class="pt-field-label" for="q">Your question</label>
        <%= f.text_field :q,
              value: @query,
              placeholder: "e.g. anything good under $200 right now?",
              class: "pt-input pt-input-block",
              autofocus: true,
              autocomplete: "off",
              maxlength: 240 %>
      </div>
      <div class="pt-form-actions" style="margin-top: 12px;">
        <%= f.submit "Ask", class: "pt-btn pt-btn-primary pt-btn-lg" %>
        <% if @query.present? %>
          <%= link_to "Clear", assistant_path, class: "pt-link-btn" %>
        <% end %>
      </div>
    <% end %>

    <% if @answer && @answer.source != "empty" %>
      <section class="pt-panel" style="margin-top: 28px;">
        <div class="pt-panel-head" style="padding: 18px 22px 0;">
          <div>
            <div class="pt-panel-eyebrow">▌ <%= @answer.source == "ai" ? "AI ANSWER" : "TOP MATCHES" %></div>
            <h2 class="pt-panel-title">Suggestions for "<%= @query.truncate(80) %>"</h2>
          </div>
          <span class="pt-source pt-source-<%= @answer.source == "ai" ? "auto" : "manual" %>"
                title="<%= @answer.source == "ai" ? "Generated by AI" : "Heuristic keyword match — AI not available" %>">
            <%= @answer.source == "ai" ? "AI" : "local" %>
          </span>
        </div>

        <% if @answer.summary.present? %>
          <p style="padding: 12px 22px 0; color: var(--ink-2);"><%= @answer.summary %></p>
        <% end %>

        <% if @answer.picks.any? %>
          <ol style="list-style:none;margin:14px 0 0;padding:0 22px 22px;">
            <% @answer.picks.each_with_index do |pick, i| %>
              <li style="display:flex;gap:16px;padding:14px 0;border-top:1px solid var(--line-2);">
                <span class="pt-mono" style="color:var(--muted);font-size:13px;min-width:24px;">#<%= i + 1 %></span>
                <div style="flex:1;min-width:0;">
                  <%= link_to pick.product.name, pick.product, class: "pt-strong", style: "text-decoration:none;color:inherit;" %>
                  <div class="pt-muted" style="font-size:13px;margin-top:2px;"><%= pick.reason %></div>
                </div>
                <div style="text-align:right;">
                  <% latest = pick.product.latest_price %>
                  <% if latest %>
                    <div class="pt-mono pt-strong">$<%= sprintf("%.2f", latest) %></div>
                    <div class="pt-muted small">latest</div>
                  <% end %>
                </div>
              </li>
            <% end %>
          </ol>
        <% else %>
          <p style="padding: 12px 22px 22px; color: var(--muted);">
            No matching products on your watchlist. Try a different question or add more products first.
          </p>
        <% end %>
      </section>
    <% elsif @query.present? && @products.empty? %>
      <div class="pt-empty" style="margin-top: 24px;">
        <h2>Your watchlist is empty</h2>
        <p>The assistant works against your tracked products. Add a product to get started.</p>
        <%= link_to "+ Add a product", new_product_path, class: "pt-btn pt-btn-primary" %>
      </div>
    <% elsif @example_questions.any? %>
      <section style="margin-top: 24px;">
        <div class="pt-eyebrow" style="margin-bottom: 12px;">Try one of these</div>
        <div style="display: flex; flex-wrap: wrap; gap: 8px;">
          <% @example_questions.each do |q| %>
            <%= link_to q, assistant_path(q: q), class: "pt-btn pt-btn-secondary", style: "border-radius: 980px; font-weight: 400;" %>
          <% end %>
        </div>
      </section>
    <% end %>
  </section>
</main>
