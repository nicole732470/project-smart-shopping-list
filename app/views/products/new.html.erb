<main class="pt-page">
  <div class="container-xl pt-content pt-narrow">
    <header class="pt-form-head">
      <div class="pt-eyebrow">Add a product</div>
      <h1 class="pt-h1">Track a new product</h1>
      <p class="pt-lede">Paste a product link and we'll fetch the title, image, and current price. If the site isn't supported, fill in the details by hand.</p>
    </header>

    <%= render "form", product: @product, manual: @manual %>
  </div>
</main>
