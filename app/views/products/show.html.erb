<main class="pt-page">
  <div class="container-xl pt-content">
    <nav class="pt-crumbs" aria-label="Breadcrumb">
      <span class="pt-crumb"><%= link_to "Home", root_path %></span>
      <span class="pt-crumb-sep">/</span>
      <span class="pt-crumb"><%= link_to "Products", products_path %></span>
      <span class="pt-crumb-sep">/</span>
      <span class="pt-crumb pt-crumb-current"><%= @product.name %></span>
    </nav>

    <% if @alert_trigger_record %>
      <div class="pt-flash" role="status"
           style="border-left: 3px solid var(--green); background: var(--green-50); margin-top: 12px;">
        <span class="pt-flash-icon" style="background: var(--green);">🎉</span>
        <div class="pt-flash-body">
          <div class="pt-flash-label">PRICE ALERT TRIGGERED</div>
          <div class="pt-flash-msg">
            $<%= sprintf("%.2f", @alert_trigger_record.price) %>
            <% if @alert_trigger_record.store_name.present? %>at <%= @alert_trigger_record.store_name %><% end %>
            · <%= time_ago_in_words(@product.last_alerted_at) %> ago
            <% if @product.target_price.present? %>
              · target: $<%= sprintf("%.2f", @product.target_price) %>
            <% end %>
          </div>
        </div>
      </div>
    <% end %>

    <% latest = @product.latest_price %>
    <% lowest = @product.lowest_price %>
    <% lowest_store = @lowest_price_record&.store_name %>
    <% trend = @product.respond_to?(:price_trend) ? @product.price_trend : nil %>
    <% trend_label = case trend
                     when 1 then "Up"
                     when -1 then "Down"
                     else "Stable"
                     end %>
    <% trend_color, trend_bg = case trend
                               when 1 then [ "var(--orange)", "#fff3e6" ]
                               when -1 then [ "var(--green)", "var(--green-50)" ]
                               else [ "var(--muted-2)", "var(--bg-2)" ]
                               end %>

    <div class="pt-detail-grid">
      <aside class="pt-detail-side">
        <div class="pt-prod-card">
          <div class="pt-prod-media">
            <% if @product.image_url.present? %>
              <%= image_tag @product.image_url, alt: @product.name %>
            <% else %>
              <div class="pt-img-fallback pt-img-fallback-lg"><%= render "shared/icon", name: "package", size: 64 %></div>
            <% end %>
          </div>
          <div class="pt-prod-body">
            <span class="pt-tag"><%= @product.category %></span>
            <h1 class="pt-prod-title"><%= @product.name %></h1>
            <% if @product.description.present? %>
              <p class="pt-prod-desc"><%= @product.description %></p>
            <% end %>

            <div class="pt-rule"></div>

            <dl class="pt-meta">
              <% if @product.source_url.present? %>
                <dt>Tracked from</dt>
                <dd>
                  <%= link_to (URI.parse(@product.source_url).host.to_s rescue @product.source_url),
                        @product.source_url, target: "_blank", rel: "noopener noreferrer",
                        class: "pt-mono pt-link" %>
                </dd>
              <% end %>
              <% if @product.last_fetched_at %>
                <dt>Last refresh</dt>
                <dd class="pt-mono"><%= time_ago_in_words(@product.last_fetched_at) %> ago</dd>
              <% end %>
              <% if @product.target_price.present? %>
                <dt>🎯 Notify at</dt>
                <dd class="pt-mono" style="color: var(--accent-700);">
                  $<%= sprintf("%.2f", @product.target_price) %>
                </dd>
              <% end %>
              <dt>Tracking since</dt>
              <dd class="pt-mono"><%= time_ago_in_words(@product.created_at) %> ago</dd>
            </dl>

            <% if @product.last_fetch_error.present? %>
              <div class="pt-flash" role="alert" style="border-left: 3px solid var(--orange); margin-top: 12px;">
                <span class="pt-flash-icon" style="background: var(--orange);">!</span>
                <div class="pt-flash-body">
                  <div class="pt-flash-label">REFRESH FAILED</div>
                  <div class="pt-flash-msg"><%= @product.last_fetch_error %></div>
                </div>
              </div>
            <% end %>

            <div class="pt-rule"></div>

            <div class="pt-prod-stats">
              <div>
                <div class="pt-stat-label">LATEST</div>
                <div class="pt-prod-price">
                  <% if latest %>$<%= sprintf("%.2f", latest) %><% else %>—<% end %>
                </div>
                <% if trend %>
                  <span class="pt-trend" style="color: <%= trend_color %>; background: <%= trend_bg %>;">
                    <span><%= trend_label %></span>
                  </span>
                <% end %>
              </div>
              <div>
                <div class="pt-stat-label">LOWEST EVER</div>
                <div class="pt-prod-price" style="color: var(--accent-700);">
                  <% if lowest %>$<%= sprintf("%.2f", lowest) %><% else %>—<% end %>
                </div>
                <% if lowest_store %>
                  <div class="pt-muted small">@ <%= lowest_store %></div>
                <% end %>
              </div>
            </div>

            <div class="pt-prod-actions">
              <% if @product.source_url.present? %>
                <%= button_to fetch_price_product_path(@product), method: :post,
                      class: "pt-btn pt-btn-primary pt-btn-block",
                      data: { turbo_confirm: "Fetch the latest price from the source URL? This may take a few seconds." },
                      form: { style: "width: 100%;" } do %>
                  ↻ Fetch latest from source
                <% end %>
              <% end %>
              <%= link_to new_product_price_record_path(@product), class: "pt-btn pt-btn-secondary pt-btn-block" do %>
                <span class="pt-btn-icon">+</span> Log a price
              <% end %>
              <div class="pt-prod-actions-row">
                <%= link_to "Edit", edit_product_path(@product), class: "pt-link-btn" %>
                <%= link_to "Delete", @product, data: { turbo_method: :delete, turbo_confirm: "Delete this product and all its price records?" }, class: "pt-link-btn pt-link-btn-danger" %>
              </div>
            </div>
          </div>
        </div>
      </aside>

      <section class="pt-detail-main">
        <div class="pt-panel">
          <div class="pt-panel-head">
            <div>
              <div class="pt-panel-eyebrow">▌ HISTORY</div>
              <h2 class="pt-panel-title">Price chart</h2>
            </div>
            <%= link_to new_product_price_record_path(@product), class: "pt-btn pt-btn-primary" do %>
              <span class="pt-btn-icon">+</span> Add price
            <% end %>
          </div>
          <% if @price_records.any? %>
            <%
              prices = @price_records.map { |r| r.price.to_f }
              chart_min = prices.min
              chart_max = prices.max
              chart_first = prices.first
              chart_last = prices.last
              chart_summary = "Price history line chart for #{@product.name}. " \
                              "#{@price_records.size} observations. " \
                              "Lowest recorded: $#{sprintf('%.2f', chart_min)}. " \
                              "Highest recorded: $#{sprintf('%.2f', chart_max)}. " \
                              "First recorded: $#{sprintf('%.2f', chart_first)}. " \
                              "Most recent: $#{sprintf('%.2f', chart_last)}."
            %>
            <div class="pt-chart-wrap" style="padding-bottom: 22px;" role="img" aria-label="<%= chart_summary %>">
              <p class="visually-hidden"><%= chart_summary %> The full price ledger below contains the same data in table form.</p>
              <%= line_chart @chart_data,
                    height: "260px",
                    thousands: ",",
                    prefix: "$",
                    round: 2,
                    library: {
                      elements: { point: { radius: 4, hoverRadius: 6 } },
                      interaction: { mode: "nearest", intersect: false }
                    } %>
            </div>
          <% else %>
            <div class="pt-empty-filter" style="margin: 0 22px 22px;">
              <div class="pt-empty-icon"><%= render "shared/icon", name: "trend-up", size: 32 %></div>
              <h3>No observations yet</h3>
              <p>Log the first price to start the history.</p>
            </div>
          <% end %>
        </div>

        <% if @lowest_price_record %>
          <div class="pt-pin">
            <div class="pt-pin-icon">◉</div>
            <div class="pt-pin-body">
              <div class="pt-stat-label">LOWEST PRICE POINT</div>
              <div class="pt-pin-line">
                <span class="pt-mono pt-strong" style="color: var(--accent-700); font-size: 1.5rem;">
                  $<%= sprintf("%.2f", @lowest_price_record.price) %>
                </span>
                <span class="pt-muted">
                  @ <%= @lowest_price_record.store_name %> · <%= @lowest_price_record.recorded_at.strftime("%b %d, %Y") %>
                </span>
              </div>
            </div>
          </div>
        <% end %>

        <% if @price_records.any? %>
          <div class="pt-panel">
            <div class="pt-panel-head">
              <div>
                <div class="pt-panel-eyebrow">▌ LEDGER</div>
                <h2 class="pt-panel-title">All observations <span class="pt-mono pt-muted small">· <%= @price_records.size %></span></h2>
              </div>
            </div>
            <div class="pt-table-wrap" style="border-radius: 0; border: none; border-top: 1px solid var(--line-2);">
              <table class="pt-table">
                <thead>
                  <tr>
                    <th>#</th>
                    <th class="pt-th-num">Price</th>
                    <th>Store</th>
                    <th>Source</th>
                    <th>Date</th>
                    <th>Notes</th>
                    <th></th>
                  </tr>
                </thead>
                <tbody>
                  <% total = @price_records.size %>
                  <% @price_records.each_with_index do |record, i| %>
                    <% is_lowest = lowest && record.price.to_f == lowest.to_f %>
                    <tr>
                      <td class="pt-mono pt-muted"><%= sprintf("%03d", total - i) %></td>
                      <td class="pt-th-num pt-mono pt-strong" style="<%= 'color: var(--accent-700);' if is_lowest %>">
                        $<%= sprintf("%.2f", record.price) %>
                      </td>
                      <td><%= record.store_name %></td>
                      <td>
                        <% src_class = record.source == "scraped" ? "pt-source-auto" : "pt-source-manual" %>
                        <span class="pt-source <%= src_class %>"><%= record.source == "scraped" ? "auto" : "manual" %></span>
                      </td>
                      <td class="pt-mono pt-muted"><%= record.recorded_at.strftime("%b %d") %></td>
                      <td class="pt-muted small"><%= record.notes.presence || "—" %></td>
                      <td>
                        <div class="pt-row-actions">
                          <%= link_to "View", price_record_path(record), class: "pt-icon-btn" %>
                          <%= link_to "Edit", edit_price_record_path(record), class: "pt-icon-btn" %>
                          <%= link_to "Del", price_record_path(record), data: { turbo_method: :delete, turbo_confirm: "Delete this price record?" }, class: "pt-icon-btn pt-icon-btn-danger" %>
                        </div>
                      </td>
                    </tr>
                  <% end %>
                </tbody>
              </table>
            </div>
          </div>
        <% end %>
      </section>
    </div>
  </div>
</main>
