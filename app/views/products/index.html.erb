<main class="pt-page">
  <section class="pt-hero">
    <div class="container-xl">
      <div class="pt-hero-grid">
        <div>
          <div class="pt-eyebrow">Your products</div>
          <h1 class="pt-h1">Products you're watching</h1>
          <p class="pt-lede">
            Paste a link from Amazon, Target, Walmart, Best Buy or Lululemon
            and we'll log the title, image, and current price, then watch
            for drops across stores.
          </p>
        </div>
        <aside class="pt-hero-cta">
          <%= link_to new_product_path, class: "pt-hero-add" do %>
            <span class="pt-hero-add-plus" aria-hidden="true"><%= render "shared/icon", name: "plus", size: 22 %></span>
            <span class="pt-hero-add-body">
              <span class="pt-hero-add-eyebrow">Start tracking</span>
              <span class="pt-hero-add-title">Add a product</span>
              <span class="pt-hero-add-sub">Paste any product link, we'll fetch the price and watch for drops.</span>
            </span>
            <span class="pt-hero-add-arrow" aria-hidden="true"><%= render "shared/icon", name: "arrow-right", size: 20 %></span>
          <% end %>
          <div class="pt-hero-meta">
            <span class="pt-hero-meta-dot"></span>
            <span><strong><%= @pagy&.count || @products.size %></strong> <%= "product".pluralize(@pagy&.count || @products.size) %> tracked</span>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <%= form_with url: products_path, method: :get, local: true, data: { controller: "auto-submit", turbo_frame: "_top" } do |f| %>
    <section class="pt-toolbar-wrap">
      <div class="container-xl">
        <div class="pt-toolbar">
          <div class="pt-search">
            <span class="pt-search-icon"><%= render "shared/icon", name: "search", size: 16 %></span>
            <%= f.text_field :search,
                  value: params[:search],
                  placeholder: "Search by name, category, description…",
                  class: "pt-search-input",
                  data: { action: "input->auto-submit#queue" } %>
            <% if params[:search].present? %>
              <%= link_to "×", products_path(params.permit(:category, :sort).to_h), class: "pt-search-clear", "aria-label": "Clear search" %>
            <% end %>
          </div>

          <div class="pt-filter-group">
            <label class="pt-filter-label" for="category">Category</label>
            <%= f.select :category,
                  options_for_select([ [ "All", "" ] ] + @categories, params[:category]),
                  {}, class: "pt-select", data: { action: "change->auto-submit#submitNow" } %>
          </div>

          <div class="pt-filter-group">
            <label class="pt-filter-label" for="sort">Sort</label>
            <%= f.select :sort,
                  options_for_select(
                    [
                      [ "Newest first", "newest" ],
                      [ "Oldest first", "oldest" ],
                      [ "Name · A→Z",   "name_asc" ],
                      [ "Name · Z→A",   "name_desc" ],
                      [ "Price · low → high",  "price_asc" ],
                      [ "Price · high → low",  "price_desc" ]
                    ],
                    params[:sort].presence || "newest"
                  ),
                  {}, class: "pt-select", data: { action: "change->auto-submit#submitNow" } %>
          </div>

          <% if params[:search].present? || params[:category].present? || (params[:sort].present? && params[:sort] != "newest") %>
            <%= link_to "Clear filters", products_path, class: "pt-link-btn pt-link-btn-strong" %>
          <% end %>

          <%# Keep a hidden submit so Enter in the search box still posts the form,
              and Stimulus is free to call requestSubmit() without warnings. %>
          <%= f.submit "Apply", style: "display:none;", tabindex: -1, "aria-hidden": "true" %>
        </div>

        <div class="pt-result-row">
          <span class="pt-result-count">
            <% if @pagy && @pagy.count > @products.size %>
              Showing <%= @pagy.from %>–<%= @pagy.to %> of <%= @pagy.count %>
              <%= "product".pluralize(@pagy.count) %>
            <% else %>
              Showing <%= @products.size %> of <%= Current.user.products.count %> products
            <% end %>
          </span>
        </div>
      </div>
    </section>
  <% end %>

  <section class="container-xl pt-content">
    <% if @products.any? %>
      <div class="pt-grid">
        <% @products.each do |product| %>
          <% latest = product.latest_price %>
          <% lowest = product.lowest_price %>
          <% latest_store = product.latest_store %>
          <% trend = product.respond_to?(:price_trend) ? product.price_trend : nil %>
          <% trend_label = case trend
                           when :up then "Up"
                           when :down then "Down"
                           when :stable then "Stable"
                           end %>
          <% trend_color, trend_bg = case trend
                                     when :up then [ "var(--orange)", "#fff3e6" ]
                                     when :down then [ "var(--green)", "var(--green-50)" ]
                                     else [ "var(--muted-2)", "var(--bg-2)" ]
                                     end %>
          <article class="pt-card">
            <%= link_to product_path(product), class: "pt-card-media", style: "text-decoration: none; color: inherit;" do %>
              <% if product.image_url.present? %>
                <%= image_tag product.image_url, alt: product.name %>
              <% else %>
                <div class="pt-img-fallback"><%= render "shared/icon", name: "package", size: 48 %></div>
              <% end %>
              <div class="pt-card-media-shade"></div>
              <span class="pt-tag pt-tag-overlay"><%= product.category %></span>
              <% if trend %>
                <span class="pt-trend pt-trend-float" style="color: <%= trend_color %>; background: <%= trend_bg %>;">
                  <span><%= trend_label %></span>
                </span>
              <% end %>
              <% if latest && lowest && latest > lowest %>
                <div class="pt-card-savings-chip">
                  <span class="pt-card-savings-label">SAVE</span>
                  <span class="pt-card-savings-num">$<%= sprintf("%.2f", latest - lowest) %></span>
                </div>
              <% end %>
            <% end %>
            <div class="pt-card-body">
              <% if product.source_url.present? %>
                <div class="pt-card-host"><%= URI.parse(product.source_url).host.to_s.sub(/\Awww\./, "") rescue "" %></div>
              <% end %>
              <h3 class="pt-card-title">
                <%= link_to product.name, product, style: "text-decoration: none; color: inherit;" %>
              </h3>

              <div class="pt-card-price-row">
                <div class="pt-card-price-block">
                  <div class="pt-card-price">
                    <% if latest %>$<%= sprintf("%.2f", latest) %><% else %>—<% end %>
                  </div>
                  <% if latest_store %>
                    <div class="pt-card-store pt-muted">at <%= latest_store %></div>
                  <% end %>
                </div>
              </div>

              <% if lowest %>
                <div class="pt-card-low">
                  <span class="pt-card-low-dot"></span>
                  <span class="pt-card-low-label">Lowest seen</span>
                  <span class="pt-card-low-num">$<%= sprintf("%.2f", lowest) %></span>
                </div>
              <% end %>

              <% if product.recent_alert? %>
                <div class="pt-card-low" style="color: var(--green); margin-top: 4px;">
                  <span class="pt-card-low-dot" style="background: var(--green);"></span>
                  <span class="pt-card-low-label">🎉 Alert fired</span>
                  <span class="pt-card-low-num"><%= time_ago_in_words(product.last_alerted_at) %> ago</span>
                </div>
              <% elsif product.target_price.present? %>
                <div class="pt-card-low pt-muted" style="margin-top: 4px;">
                  <span class="pt-card-low-dot" style="background: var(--muted-2);"></span>
                  <span class="pt-card-low-label">🎯 Notify at</span>
                  <span class="pt-card-low-num">$<%= sprintf("%.2f", product.target_price) %></span>
                </div>
              <% end %>
            </div>
            <div class="pt-card-foot">
              <%= link_to "View details →", product,
                    class: "pt-link-btn pt-link-btn-strong",
                    aria: { label: "View details for #{product.name}" } %>
              <div class="pt-row-actions">
                <%= link_to edit_product_path(product),
                      class: "pt-icon-btn",
                      aria: { label: "Edit #{product.name}" } do %>
                  <%= render "shared/icon", name: "edit", size: 16 %>
                <% end %>
                <%= link_to product_path(product),
                      data: { turbo_method: :delete, turbo_confirm: "Delete \"#{product.name}\"?" },
                      class: "pt-icon-btn pt-icon-btn-danger",
                      aria: { label: "Delete #{product.name}" } do %>
                  <%= render "shared/icon", name: "trash", size: 16 %>
                <% end %>
              </div>
            </div>
          </article>
        <% end %>
      </div>

      <% if @pagy && @pagy.pages > 1 %>
        <nav class="pt-pagination" aria-label="Products pagination">
          <%== pagy_nav(@pagy) %>
        </nav>
        <div class="pt-pagination-meta">
          Page <%= @pagy.page %> of <%= @pagy.pages %> · <%= @pagy.count %> products
        </div>
      <% end %>
    <% elsif params[:search].present? || params[:category].present? %>
      <div class="pt-empty-filter">
        <div class="pt-empty-icon"><%= render "shared/icon", name: "search", size: 32 %></div>
        <h3>No products match.</h3>
        <p>Try a different search term or clear your filters.</p>
        <%= link_to "Clear filters", products_path, class: "pt-btn pt-btn-secondary" %>
      </div>
    <% else %>
      <div class="pt-empty">
        <div class="pt-empty-graphic">
          <svg viewBox="0 0 220 130" width="220" height="130">
            <rect x="20" y="10" width="180" height="110" rx="6" fill="none" stroke="var(--ink)" stroke-opacity="0.15" stroke-dasharray="4 4"/>
            <line x1="40" y1="40" x2="180" y2="40" stroke="var(--ink)" stroke-opacity="0.1"/>
            <line x1="40" y1="60" x2="180" y2="60" stroke="var(--ink)" stroke-opacity="0.1"/>
            <line x1="40" y1="80" x2="140" y2="80" stroke="var(--ink)" stroke-opacity="0.1"/>
            <circle cx="170" cy="100" r="14" fill="var(--accent)"/>
            <text x="170" y="105" text-anchor="middle" font-size="16" font-weight="600" fill="white">+</text>
          </svg>
        </div>
        <h2>No products yet</h2>
        <p>Start by pasting a product link, Amazon, Target, Walmart, Best Buy or Lululemon, and we'll do the rest.</p>
        <%= link_to new_product_path, class: "pt-btn pt-btn-primary pt-btn-lg" do %>
          <span class="pt-btn-icon">+</span> Add your first product
        <% end %>
      </div>
    <% end %>
  </section>
</main>
