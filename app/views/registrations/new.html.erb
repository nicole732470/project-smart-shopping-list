<div class="pt-auth">
  <div class="pt-auth-grid">
    <aside class="pt-auth-side">
      <div class="pt-auth-mark">P/T</div>
      <div class="pt-auth-side-eyebrow">Get started</div>
      <h1 class="pt-auth-side-title">Track every price change across stores.</h1>
      <p class="pt-auth-side-lede">
        Save a product link once. Get a full price history, the lowest seen,
        and a chart of every observation, all in one place.
      </p>
      <div class="pt-auth-side-spec">
        <div class="pt-auth-side-row">
          <span class="pt-mono">01</span>
          <span>Paste a product link.</span>
        </div>
        <div class="pt-auth-side-row">
          <span class="pt-mono">02</span>
          <span>We grab the title, image, and current price.</span>
        </div>
        <div class="pt-auth-side-row">
          <span class="pt-mono">03</span>
          <span>Watch the chart for drops across stores.</span>
        </div>
      </div>
    </aside>

    <div class="pt-auth-form-wrap">
      <%= form_with model: @user, url: registration_path, local: true, class: "pt-auth-form" do |form| %>
        <div class="pt-eyebrow">Create an account</div>
        <h2 class="pt-h1">Start tracking</h2>

        <% if @user.errors.any? %>
          <div class="pt-flash" role="alert" style="border-left: 3px solid var(--red); margin: 18px 0;">
            <span class="pt-flash-icon" style="background: var(--red);">!</span>
            <div class="pt-flash-body">
              <div class="pt-flash-label">FIX TO CONTINUE</div>
              <div class="pt-flash-msg">
                <% @user.errors.full_messages.each do |msg| %>
                  <div><%= msg %></div>
                <% end %>
              </div>
            </div>
          </div>
        <% end %>

        <div class="pt-form" style="margin-top: 24px;">
          <div class="pt-field">
            <label class="pt-field-label" for="user_email_address">Email address</label>
            <%= form.email_field :email_address,
                  required: true, autofocus: true, autocomplete: "username",
                  class: "pt-input" %>
          </div>
          <div class="pt-field">
            <label class="pt-field-label" for="user_password">Password</label>
            <%= form.password_field :password,
                  required: true, autocomplete: "new-password", maxlength: 72,
                  class: "pt-input" %>
          </div>
          <div class="pt-field">
            <label class="pt-field-label" for="user_password_confirmation">Confirm password</label>
            <%= form.password_field :password_confirmation,
                  required: true, autocomplete: "new-password", maxlength: 72,
                  class: "pt-input" %>
          </div>

          <%= form.submit "Create account", class: "pt-btn pt-btn-primary pt-btn-lg pt-btn-block" %>
        </div>

        <div class="pt-auth-foot">
          Already have an account? <%= link_to "Sign in", new_session_path, class: "pt-link pt-link-strong" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
