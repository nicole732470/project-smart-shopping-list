<main class="pt-page">
  <div class="container-xl pt-content pt-narrow">
    <nav class="pt-crumbs" aria-label="Breadcrumb">
      <span class="pt-crumb"><%= link_to "Home", root_path %></span>
      <span class="pt-crumb-sep">/</span>
      <span class="pt-crumb"><%= link_to "Price Records", price_records_path %></span>
      <span class="pt-crumb-sep">/</span>
      <span class="pt-crumb pt-crumb-current">#<%= sprintf("%03d", @price_record.id) %></span>
    </nav>

    <header style="margin-bottom: 28px;">
      <div class="pt-eyebrow">Observation</div>
      <h1 class="pt-h1" style="font-size: 32px;">$<%= sprintf("%.2f", @price_record.price) %> at <%= @price_record.store_name %></h1>
      <p class="pt-lede"><%= link_to @price_record.product.name, @price_record.product, class: "pt-link pt-link-strong" %></p>
    </header>

    <div class="pt-panel" style="padding: 22px;">
      <dl class="pt-meta" style="grid-template-columns: 140px 1fr; gap: 14px 18px;">
        <dt>Price</dt>
        <dd class="pt-mono pt-strong" style="font-size: 18px;">$<%= sprintf("%.2f", @price_record.price) %></dd>

        <dt>Store</dt>
        <dd class="pt-strong"><%= @price_record.store_name %></dd>

        <dt>Source</dt>
        <dd>
          <% src_class = @price_record.source == "scraped" ? "pt-source-auto" : "pt-source-manual" %>
          <span class="pt-source <%= src_class %>"><%= @price_record.source == "scraped" ? "auto" : "manual" %></span>
        </dd>

        <dt>Recorded</dt>
        <dd class="pt-mono"><%= @price_record.recorded_at.strftime("%B %d, %Y at %I:%M %p") %></dd>

        <dt>Purchase URL</dt>
        <dd>
          <% if @price_record.url.present? %>
            <%= link_to @price_record.url, @price_record.url, target: "_blank", rel: "noopener noreferrer", class: "pt-mono pt-link" %>
          <% else %>
            <span class="pt-muted">—</span>
          <% end %>
        </dd>

        <dt>Notes</dt>
        <dd><%= @price_record.notes.presence || content_tag(:span, "—", class: "pt-muted") %></dd>
      </dl>
    </div>

    <div class="pt-form-actions" style="margin-top: 28px; flex-direction: row; justify-content: center;">
      <%= link_to "Edit", edit_price_record_path(@price_record), class: "pt-btn pt-btn-secondary" %>
      <%= link_to "Back to product", @price_record.product, class: "pt-btn pt-btn-ghost" %>
      <%= link_to "Delete", @price_record, data: { turbo_method: :delete, turbo_confirm: "Delete this record?" }, class: "pt-link-btn pt-link-btn-danger" %>
    </div>
  </div>
</main>
