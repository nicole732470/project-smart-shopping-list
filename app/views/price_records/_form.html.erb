<%= form_with model: [@product, price_record], local: true, class: "pt-form" do |f| %>
  <% if price_record.errors.any? %>
    <div class="pt-flash" role="alert" style="border-left: 3px solid var(--red);">
      <span class="pt-flash-icon" style="background: var(--red);">!</span>
      <div class="pt-flash-body">
        <div class="pt-flash-label">FIX TO CONTINUE</div>
        <div class="pt-flash-msg">
          <% price_record.errors.full_messages.each do |msg| %>
            <div><%= msg %></div>
          <% end %>
        </div>
      </div>
    </div>
  <% end %>

  <div class="pt-field">
    <label class="pt-field-label" for="price_record_price">Price <span class="pt-field-req">required</span></label>
    <div class="pt-input-prefix">
      <span class="pt-input-prefix-tag">$</span>
      <%= f.number_field :price, step: 0.01, min: 0, class: "pt-input", placeholder: "0.00", required: true %>
    </div>
  </div>

  <div class="pt-field">
    <label class="pt-field-label" for="price_record_store_name">Store</label>
    <%= f.select :store_name,
          ["Amazon", "Walmart", "Target", "Best Buy", "Costco", "eBay", "Newegg", "B&H Photo", "Apple Store", "Lululemon", "Other"],
          { prompt: "Select a store" },
          class: "pt-select pt-input pt-input-block" %>
  </div>

  <div class="pt-field">
    <label class="pt-field-label" for="price_record_url">Purchase URL <span class="pt-field-req">optional</span></label>
    <%= f.url_field :url, class: "pt-input", placeholder: "https://www.amazon.com/..." %>
    <div class="pt-field-hint">Direct link to this product on the store's website.</div>
  </div>

  <div class="pt-field">
    <label class="pt-field-label" for="price_record_recorded_at">Date recorded</label>
    <%= f.datetime_local_field :recorded_at, class: "pt-input",
          value: (price_record.recorded_at || Time.current).strftime("%Y-%m-%dT%H:%M") %>
  </div>

  <div class="pt-field">
    <label class="pt-field-label" for="price_record_notes">Notes <span class="pt-field-req">optional</span></label>
    <%= f.text_area :notes, class: "pt-input", rows: 2, placeholder: "e.g. Black Friday deal, coupon applied..." %>
  </div>

  <div class="pt-form-actions">
    <%= f.submit (price_record.new_record? ? "Log price" : "Save changes"), class: "pt-btn pt-btn-primary pt-btn-lg" %>
    <%= link_to "Cancel", (price_record.new_record? ? @product : price_record), class: "pt-link-btn" %>
  </div>
<% end %>
